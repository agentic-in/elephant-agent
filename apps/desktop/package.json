{
  "name": "@elephant/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:dashboard": "node scripts/build-dashboard.mjs",
    "dev": "npm run build:dashboard && tauri dev",
