{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Elephant Agent",
  "version": "0.1.0",
  "identifier": "ai.agentic.elephant.desktop",
  "build": {
    "beforeDevCommand": "node scripts/build-dashboard.mjs",
    "beforeBuildCommand": "node scripts/build-dashboard.mjs",
    "frontendDist": "../../dashboard/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Elephant Agent",
        "label": "main",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 680,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "Productivity",
    "resources": {
      "../../api": "python/apps/api",
      "../../cli": "python/apps/cli",
      "../../reflect": "python/apps/reflect",
      "../../learning_agents": "python/apps/learning_agents",
      "../../provider_runtime.py": "python/apps/provider_runtime.py",
      "../../provider_runtime_support.py": "python/apps/provider_runtime_support.py",
      "../../learning_worker_command.py": "python/apps/learning_worker_command.py",
      "../../learning_worker_runtime.py": "python/apps/learning_worker_runtime.py",
      "../../logging_setup.py": "python/apps/logging_setup.py",
      "../../runtime_layout.py": "python/apps/runtime_layout.py",
      "../../episode_runtime.py": "python/apps/episode_runtime.py",
      "../../launcher.py": "python/apps/launcher.py",
      "../../../packages": "python/packages"
    }
  }
}
